# みんなのWA ローカル開発用環境変数
# .env に同じキーをセットして `npm run dev` で起動

# ==========================================
# Supabase 接続（本番と同じプロジェクト・dev スキーマを使う）
# ==========================================
# 本番: legacy_minanowa スキーマ
# 開発: legacy_minanowa_dev スキーマ（本番データのコピー、書き換え自由）
SUPABASE_URL=https://uffodcgcpykrdawyeekx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=（Render Dashboard の minanowa サービス Environment タブからコピー）
SUPABASE_SCHEMA=legacy_minanowa_dev
USE_SUPABASE=true

# ==========================================
# その他
