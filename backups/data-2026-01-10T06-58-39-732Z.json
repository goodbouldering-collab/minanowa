  "faqs": [
    {
      "id": "faq-1",
      "category": "参加について",
      "question": "誰でも参加できますか？",
      "answer": "はい、彦根周辺で事業を営む方、または地域とつながりのある方であればどなたでも参加できます。個人事業主、法人代表者、フリーランス、副業を始めたい方など幅広く歓迎します。"
    },
    {
      "id": "faq-2",
      "category": "参加について",
      "question": "参加費用はいくらですか？",
      "answer": "交流会の参加費は通常3,000円＋持ち寄り一品、または4,000円となります。新規の方を連れてこられた場合は500円のキャッシュバックがあります。初めての方でも気軽にご参加いただけます。"
    },
    {
      "id": "faq-3",
      "category": "交流会について",
      "question": "どのような雰囲気の交流会ですか？",
      "answer": "フリートーク形式で、堅苦しくない和やかな雰囲気です。参加者同士で名刺交換をしたり、それぞれの事業について自由に話し合えます。希望者は1分間の自己紹介タイムもあり、どんな人と出会いたいかを伝えることができます。"
    },
    {
      "id": "faq-4",
      "category": "交流会について",
      "question": "開催頻度はどのくらいですか？",
      "answer": "月に1〜2回のペースで定期的に開催しています。詳しい日程はイベントセクションやLINEグループでお知らせしています。"
    },
    {
      "id": "faq-5",
      "category": "ビジネス",
      "question": "コラボレーションの実績はありますか？",
      "answer": "はい、多数の実績があります。飲食店とIT企業のコラボレーション、建設業と不動産業のマッチング、複数事業者による共同イベント開催など、様々な形でのコラボが生まれています。"
    },
    {
      "id": "faq-6",
      "category": "ビジネス",
      "question": "体験ブースや出店は可能ですか？",
      "answer": "はい、可能です！交流会参加費＋1,000円で体験ブースや出店ができます。自社商品のPRや実際に体験してもらう機会として、多くの方にご利用いただいています。"
    },
    {
      "id": "faq-7",
      "category": "その他",
      "question": "オンラインでの交流はありますか？",
      "answer": "はい、LINEグループで日常的に情報交換やコミュニケーションを行っています。遠方の方や都合が合わない方も、オンラインで繋がることができます。"
    },
    {
      "id": "faq-8",
      "category": "その他",
      "question": "目標メンバー数はどのくらいですか？",
      "answer": "「目指せ1000人！」を合言葉に、地域の事業者ネットワークを広げています。現在も着実にメンバーが増えており、みんなで目標達成を目指しています。"
    }
  ]
