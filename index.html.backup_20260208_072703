/* ========== DX STEPS INTERACTIVE ========== */
(function initDxSteps(){
  const steps=document.querySelectorAll('.dx-step');
  if(!steps.length) return;

  /* Scroll-triggered staggered reveal */
  const dxObs=new IntersectionObserver((entries)=>{
    entries.forEach(entry=>{
      if(entry.isIntersecting){
        const step=entry.target;
        const delay=parseInt(step.dataset.step||1)*200;
        setTimeout(()=>{
          step.classList.add('dx-visible');
        },delay);
        dxObs.unobserve(step);
      }
    });
  },{threshold:.15,rootMargin:'0px 0px -40px 0px'});
  steps.forEach(s=>dxObs.observe(s));

  /* Click to activate/toggle step with enhanced effects */
  steps.forEach(step=>{
    step.addEventListener('click',()=>{
      const wasActive=step.classList.contains('dx-active');
      steps.forEach(s=>s.classList.remove('dx-active'));
      if(!wasActive){
        step.classList.add('dx-active');
        /* Pulse animation on number */
        const num=step.querySelector('.dx-step-num');
        num.style.animation='step-click-pulse .5s cubic-bezier(.175,.885,.32,1.275)';
        num.addEventListener('animationend',()=>{num.style.animation='none'},{once:true});
        /* Emit particles from the number icon */
        const colors={'green':'#0d9488','cyan':'#0891b2','purple':'#7c3aed','orange':'#d97706'};
        const clr=colors[step.dataset.color]||'#10b981';
        const rect=num.getBoundingClientRect();
        for(let i=0;i<6;i++){
          const p=document.createElement('span');
          const angle=Math.random()*Math.PI*2;
          const dist=30+Math.random()*25;
          p.style.cssText=`position:fixed;width:${3+Math.random()*4}px;height:${3+Math.random()*4}px;
            border-radius:50%;background:${clr};pointer-events:none;z-index:999;opacity:1;
            left:${rect.left+rect.width/2}px;top:${rect.top+rect.height/2}px;
            transition:all .6s cubic-bezier(.175,.885,.32,1.275)`;
          document.body.appendChild(p);
          requestAnimationFrame(()=>{
            p.style.transform=`translate(${Math.cos(angle)*dist}px,${Math.sin(angle)*dist}px) scale(0)`;
            p.style.opacity='0';
          });
          setTimeout(()=>p.remove(),700);
        }
        /* Smooth scroll to keep step visible */
        step.scrollIntoView({behavior:'smooth',block:'nearest'});
      }
    });
  });

  /* Auto-cycle through steps for attention */
  let autoCycleTimer;
  function startAutoCycle(){
    let idx=0;
    autoCycleTimer=setInterval(()=>{
      if(document.querySelector('.dx-step.dx-active')) return; /* User interacted, skip */
      steps[idx].classList.add('dx-visible');
      idx=(idx+1)%steps.length;
    },800);
  }
  /* Stop auto-cycle on any user interaction */
  const dxContainer=document.getElementById('dxSteps');
  if(dxContainer){
    dxContainer.addEventListener('mouseenter',()=>clearInterval(autoCycleTimer));
    dxContainer.addEventListener('touchstart',()=>clearInterval(autoCycleTimer),{passive:true});
  }
})();

/* ========== SECTION TITLE INTERACTIVE EFFECTS ========== */
document.addEventListener('click',e=>{
  const h2=e.target.closest('.sec-head h2');
  if(!h2) return;
  h2.style.animation='title-bounce .5s cubic-bezier(.25,.46,.45,.94)';
  h2.addEventListener('animationend',()=>{h2.style.animation='none'},{once:true});
});

/* Parallax bg shapes on scroll */
window.addEventListener('scroll',()=>{
  const y=window.scrollY;
  document.querySelectorAll('.bg-shape').forEach((s,i)=>{
    s.style.transform=`translateY(${y*(0.02+i*0.01)}px)`;
  });
},{passive:true});
</script>
