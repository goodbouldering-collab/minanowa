.footer-grid a{color:rgba(255,255,255,.45);font-size:.85rem;display:block;margin-bottom:.4rem;transition:all .35s cubic-bezier(.25,.46,.45,.94);
  position:relative;padding-left:0}
.footer-grid a:hover{color:var(--c3);transform:translateX(5px);padding-left:.2rem}
.footer-social a{display:inline-flex;width:36px;height:36px;border-radius:50%;
  align-items:center;justify-content:center;background:rgba(255,255,255,.08);
  margin-right:.3rem;transition:var(--spring);font-size:1rem;border:1px solid rgba(255,255,255,.08)}
.footer-social a:hover{background:linear-gradient(135deg,var(--c1),var(--c3));color:#fff;transform:translateY(-4px) scale(1.05);
  box-shadow:0 6px 20px rgba(13,148,136,.35);border-color:transparent}
.footer-bot{text-align:center;padding-top:1.2rem;border-top:1px solid rgba(255,255,255,.05);
  color:rgba(255,255,255,.2);font-size:.78rem;position:relative;z-index:1;letter-spacing:.03em}

/* ========== MODAL ========== */
.modal-overlay{display:none;position:fixed;inset:0;background:rgba(15,23,42,.5);backdrop-filter:blur(8px);
  z-index:2000;align-items:center;justify-content:center}
.modal-overlay.active{display:flex}
.modal-box{background:var(--white);border-radius:var(--r);padding:1.8rem;max-width:480px;width:92%;
  max-height:85vh;overflow-y:auto;animation:modal-in .4s cubic-bezier(.175,.885,.32,1.275);
  box-shadow:0 8px 24px rgba(0,0,0,.05),0 24px 80px rgba(0,0,0,.1);border:1px solid rgba(0,0,0,.04)}
@keyframes modal-in{from{opacity:0;transform:translateY(30px) scale(.95)}to{opacity:1;transform:translateY(0) scale(1)}}
.modal-close{float:right;font-size:1.3rem;cursor:pointer;color:var(--tl);transition:var(--spring);
  background:none;border:none;width:32px;height:32px;border-radius:50%;display:flex;align-items:center;justify-content:center}
.modal-close:hover{color:var(--c1);background:rgba(13,148,136,.06);transform:rotate(90deg)}
.modal-title{font-size:1.25rem;font-weight:700;color:var(--td);
  margin-bottom:1.1rem;display:flex;align-items:center;gap:.4rem;letter-spacing:.02em}

/* ========== MYPAGE ========== */
.mypage-header{display:flex;align-items:center;gap:1rem;margin-bottom:1rem;padding-bottom:.8rem;
  border-bottom:1px solid rgba(0,0,0,.06)}
.mypage-avatar{width:74px;height:74px;border-radius:50%;object-fit:cover;
  border:2px solid rgba(0,0,0,.06)}
.avatar-upload{position:relative;cursor:pointer}
.avatar-upload input{position:absolute;inset:0;opacity:0;cursor:pointer}
.avatar-overlay{position:absolute;bottom:0;left:0;right:0;background:rgba(0,0,0,.5);color:#fff;
  text-align:center;font-size:.6rem;padding:.15rem;border-radius:0 0 50% 50%;backdrop-filter:blur(4px);
  opacity:0;transition:var(--transition)}
.avatar-upload:hover .avatar-overlay{opacity:1}
.mypage-info h3{font-size:1rem;font-weight:700}
.mypage-info p{color:var(--tl);font-size:.78rem}

/* ========== SEARCH ========== */
.search-box{max-width:500px;margin:0 auto .8rem;position:relative}
.search-box input{width:100%;padding:.65rem 2.5rem .65rem 1.1rem;border:1.5px solid rgba(0,0,0,.08);
  border-radius:var(--r3);font-size:.9rem;background:var(--white);transition:all .4s cubic-bezier(.25,.46,.45,.94)}
.search-box input:focus{outline:none;border-color:var(--c1);box-shadow:0 0 0 4px rgba(13,148,136,.08),0 4px 16px rgba(13,148,136,.06);transform:translateY(-1px)}
.search-box i{position:absolute;right:.9rem;top:50%;transform:translateY(-50%);color:var(--c1);font-size:.85rem}

/* ========== USER BAR ========== */
.user-bar{display:flex;align-items:center;gap:.5rem}
.user-bar img{width:30px;height:30px;border-radius:50%;object-fit:cover;cursor:pointer;
  border:2px solid transparent;background:linear-gradient(#fff,#fff) padding-box,
    linear-gradient(135deg,var(--c1),var(--c3)) border-box;transition:var(--spring)}
.user-bar img:hover{transform:scale(1.12);box-shadow:0 3px 12px rgba(16,185,129,.3)}
.user-bar .uname{font-size:.78rem;font-weight:600;cursor:pointer;transition:var(--transition)}
.user-bar .uname:hover{color:var(--c1)}

/* ========== FLOATING SHAPES ========== */
.bg-shape{position:fixed;border-radius:50%;pointer-events:none;z-index:-1;filter:blur(120px);opacity:.03;
  transition:transform 30s ease}
.bg-shape.s1{width:350px;height:350px;background:var(--c1);top:15%;left:-8%}
.bg-shape.s2{width:280px;height:280px;background:var(--c3);top:50%;right:-5%}
.bg-shape.s3{width:300px;height:300px;background:var(--accent3);bottom:10%;left:20%}

/* ========== TOOLTIP ========== */
[data-tooltip]{position:relative}
[data-tooltip]:hover::after{content:attr(data-tooltip);position:absolute;bottom:calc(100% + 8px);left:50%;
  transform:translateX(-50%);padding:.3rem .65rem;border-radius:8px;font-size:.65rem;font-weight:500;
  background:var(--td);color:#fff;white-space:nowrap;pointer-events:none;z-index:50;
  animation:tooltip-in .25s cubic-bezier(.175,.885,.32,1.275)}
@keyframes tooltip-in{from{opacity:0;transform:translateX(-50%) translateY(6px)}to{opacity:1;transform:translateX(-50%) translateY(0)}}

/* ========== BACK TO TOP ========== */
.back-to-top{position:fixed;bottom:1.5rem;right:1.5rem;width:44px;height:44px;border-radius:50%;
  background:linear-gradient(135deg,var(--c1),var(--c2));color:#fff;border:none;cursor:pointer;
  display:flex;align-items:center;justify-content:center;font-size:.9rem;z-index:999;
  box-shadow:0 4px 12px rgba(0,0,0,.08),0 6px 20px rgba(13,148,136,.15);transition:all .4s cubic-bezier(.16,1,.3,1);
  opacity:0;transform:translateY(20px);pointer-events:none}
.back-to-top.visible{opacity:1;transform:translateY(0);pointer-events:auto}
.back-to-top:hover{transform:translateY(-4px) scale(1.08);box-shadow:0 6px 16px rgba(0,0,0,.1),0 12px 32px rgba(13,148,136,.22)}
.back-to-top:active{transform:translateY(0) scale(.93)}

/* ========== NOTIFICATION TOAST ========== */
.toast{position:fixed;top:70px;right:1.5rem;z-index:3000;background:var(--white);
  border-radius:var(--r2);padding:.75rem 1.1rem;box-shadow:0 4px 20px rgba(0,0,0,.08),0 12px 40px rgba(0,0,0,.06);
  border-left:3px solid var(--c1);display:flex;align-items:center;gap:.5rem;
  transform:translateX(calc(100% + 3rem));transition:transform .4s cubic-bezier(.175,.885,.32,1.275);
  font-size:.8rem;font-weight:500;max-width:320px;backdrop-filter:blur(12px);
  visibility:hidden}
.toast.show{transform:translateX(0);visibility:visible}
.toast i{color:var(--c1);font-size:1rem}

/* ========== SKELETON LOADING ========== */
.skeleton{background:linear-gradient(110deg,rgba(0,0,0,.03) 30%,rgba(0,0,0,.06) 50%,rgba(0,0,0,.03) 70%);
  background-size:200% 100%;animation:skeleton-shimmer 1.5s ease infinite;border-radius:var(--r2)}
@keyframes skeleton-shimmer{0%{background-position:200% 0}100%{background-position:-200% 0}}

/* ========== TRUST STRIP ========== */
.trust-strip{background:linear-gradient(135deg,#ecfdf5 0%,#f0fdfa 50%,#ecfdf5 100%);
  border-bottom:1px solid rgba(13,148,136,.06);border-top:1px solid rgba(13,148,136,.06);
  padding:.9rem 1.5rem;overflow:hidden}
.trust-inner{max-width:1100px;margin:0 auto;display:flex;align-items:center;justify-content:center;
  gap:2rem;flex-wrap:wrap}
.trust-item{display:flex;align-items:center;gap:.45rem;color:var(--tm);font-size:.82rem;font-weight:600;
  white-space:nowrap;letter-spacing:.02em}
.trust-item i{color:#fff;font-size:.6rem;opacity:1;
  background:var(--c1);width:1.2rem;height:1.2rem;border-radius:50%;
  display:inline-flex;align-items:center;justify-content:center;
  box-shadow:0 1px 3px rgba(13,148,136,.2)}
/* trust strip responsive handled in main media queries above */

/* ========== COUNTER SECTION (between hero and about) ========== */
.counter-section{background:linear-gradient(135deg,#f0fdfa 0%,#ecfdf5 50%,#f0fdf4 100%);
  border-top:1px solid rgba(13,148,136,.08);border-bottom:1px solid rgba(13,148,136,.08);
  padding:1.4rem 2rem;position:relative;overflow:hidden;width:100%}
.counter-section::before{content:'';position:absolute;inset:0;
  background:transparent;pointer-events:none}
.counter-grid{max-width:1300px;margin:0 auto;display:grid;grid-template-columns:repeat(4,1fr);gap:.6rem}
/* counter responsive handled in main media queries above */
.counter-item{text-align:center;padding:.5rem;position:relative}
.counter-item:not(:last-child)::after{content:'';position:absolute;right:0;top:20%;height:60%;
  width:1px;background:linear-gradient(180deg,transparent,rgba(0,0,0,.08),transparent)}
.counter-num{font-size:2.2rem;font-weight:900;color:var(--td);
  background:linear-gradient(135deg,var(--c2),var(--c1));-webkit-background-clip:text;-webkit-text-fill-color:transparent}
.counter-label{font-size:.78rem;color:var(--tm);font-weight:500;margin-top:.2rem;letter-spacing:.03em}
.counter-icon{font-size:.95rem;color:#fff;margin-bottom:.3rem;
  width:34px;height:34px;border-radius:10px;display:inline-flex;align-items:center;justify-content:center;
  background:linear-gradient(135deg,var(--c1),var(--c3));box-shadow:0 2px 8px rgba(13,148,136,.2)}

/* ========== INTERVIEW SECTION ========== */
.interview-card{width:340px;background:var(--white);border:1px solid rgba(0,0,0,.06);
  border-radius:var(--r);box-shadow:var(--sh);overflow:hidden;flex-shrink:0;transition:var(--spring);position:relative}
.interview-card::after{content:'';position:absolute;bottom:0;left:0;right:0;height:3px;
  background:linear-gradient(90deg,var(--c1),var(--c3));transform:scaleX(0);
  transition:transform .4s ease;transform-origin:left;z-index:3}
.interview-card:hover{transform:translateY(-6px);box-shadow:0 12px 35px rgba(0,0,0,.08),0 4px 12px rgba(13,148,136,.06)}
.interview-card:hover::after{transform:scaleX(1)}
.interview-thumb{position:relative;width:100%;aspect-ratio:16/9;background:#000;overflow:hidden;cursor:pointer}
.interview-thumb img{width:100%;height:100%;object-fit:cover;transition:transform .5s ease,opacity .3s}
.interview-thumb:hover img{transform:scale(1.05);opacity:.85}
.interview-play{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;
  background:rgba(0,0,0,.3);transition:var(--transition)}
.interview-play i{font-size:2.5rem;color:#fff;filter:drop-shadow(0 2px 12px rgba(0,0,0,.4));
  transition:var(--spring)}
.interview-thumb:hover .interview-play{background:rgba(0,0,0,.35)}
.interview-thumb:hover .interview-play i{transform:scale(1.15)}
.interview-body{padding:.8rem .9rem}
.interview-speaker{display:flex;align-items:center;gap:.3rem;font-size:.78rem;color:var(--c1);font-weight:600;margin-bottom:.2rem}
.interview-title{font-size:1rem;font-weight:700;line-height:1.4;margin-bottom:.25rem;
  display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}
.interview-desc{font-size:.82rem;color:var(--tl);line-height:1.55;
  display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}
/* YouTube embed modal */
.yt-modal{display:none;position:fixed;inset:0;z-index:3000;background:rgba(0,0,0,.8);
  backdrop-filter:blur(8px);align-items:center;justify-content:center}
.yt-modal.active{display:flex}
.yt-modal-inner{width:90%;max-width:800px;position:relative;aspect-ratio:16/9;border-radius:var(--r);overflow:hidden;
  box-shadow:0 25px 80px rgba(0,0,0,.5);animation:modal-in .4s cubic-bezier(.175,.885,.32,1.275)}
.yt-modal-close{position:absolute;top:-35px;right:0;background:none;border:none;color:#fff;font-size:1.5rem;
  cursor:pointer;z-index:5;transition:var(--spring);width:32px;height:32px;display:flex;align-items:center;justify-content:center}
.yt-modal-close:hover{transform:rotate(90deg) scale(1.1)}
.yt-modal iframe{width:100%;height:100%;border:none}

/* ========== OPERATING MEMBERS SECTION ========== */
.op-card{width:200px;text-align:center;padding:1.4rem 1rem;cursor:default;background:var(--white);
  border:1px solid rgba(0,0,0,.06);border-radius:var(--r);box-shadow:var(--sh);flex-shrink:0;
  transition:var(--spring);position:relative;overflow:hidden}
.op-card::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;
  background:linear-gradient(90deg,var(--c1),var(--c3),var(--accent3));transform:scaleX(0);transition:transform .4s ease;transform-origin:left}
.op-card:hover::before{transform:scaleX(1)}
.op-card:hover{transform:translateY(-6px);box-shadow:0 12px 35px rgba(0,0,0,.08),0 4px 12px rgba(13,148,136,.06)}
.op-badge{position:absolute;top:.5rem;right:.5rem;background:linear-gradient(135deg,var(--c1),var(--c2));
