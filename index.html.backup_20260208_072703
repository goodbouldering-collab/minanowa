.op-card:hover .op-avatar{transform:scale(1.06)}
.op-role{font-size:.6rem;font-weight:600;color:#fff;margin-top:.15rem;
  background:linear-gradient(135deg,var(--c1),var(--c3));display:inline-block;padding:.12rem .5rem;border-radius:6px;
