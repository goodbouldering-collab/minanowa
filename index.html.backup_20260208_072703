<script>
/* ========== STATE ========== */
let currentUser=null, allMembers=[], allEvents=[], allBlogs=[], allBoards=[], allInterviews=[], allOpMembers=[];
let heroTitleText='つながりが、可能性を広げる';

/* ========== LOADING ========== */
window.addEventListener('load',()=>{
  setTimeout(()=>{document.getElementById('loadingScreen').classList.add('hide')},1600);
});

/* ========== INIT ========== */
document.addEventListener('DOMContentLoaded',()=>{
  initHero();
  initScrollReveal();
  initNavScroll();
  initScrollProgress();
  initCursorGlow();
  initBackToTop();
  initCounterSection();
  loadAll();
  const saved=localStorage.getItem('wa_user');
  if(saved){currentUser=JSON.parse(saved);updateNav()}
});

/* ========== TYPED HERO ========== */
function typeHeroTitle(text){
  const el=document.getElementById('heroTitle');
  const cursor=document.getElementById('typedCursor');
  el.textContent='';
  let i=0;
  function type(){
    if(i<text.length){el.textContent+=text[i];i++;setTimeout(type,60)}
    else{setTimeout(()=>{cursor.style.display='none'},2000)}
  }
  setTimeout(type,800);
}

/* ========== HERO PARTICLES ========== */
function initHero(){
  const c=document.getElementById('particles');
  for(let i=0;i<35;i++){
    const p=document.createElement('div');
    const size=8+Math.random()*55;
    const bright=Math.random()>.75;
    p.className='particle'+(bright?' bright':'');
    p.style.cssText=`width:${size}px;height:${size}px;left:${Math.random()*100}%;top:${Math.random()*100}%;
      --dur:${14+Math.random()*22}s;--dy:${-40-Math.random()*80}px;--dx:${-30+Math.random()*60}px;
      animation-delay:${-Math.random()*20}s`;
    c.appendChild(p);
  }
  /* Add geometric lines */
  for(let i=0;i<8;i++){
    const l=document.createElement('div');
    l.className='particle line';
    const h=80+Math.random()*120;
    l.style.cssText=`width:1px;height:${h}px;left:${Math.random()*100}%;top:${Math.random()*100}%;
      --dur:${20+Math.random()*15}s;--dy:${-20-Math.random()*40}px;--dx:${-10+Math.random()*20}px;
      animation-delay:${-Math.random()*15}s;transform:rotate(${Math.random()*30-15}deg)`;
    c.appendChild(l);
  }
  /* Hero photo gallery */
  initHeroPhotos();
}

function initHeroPhotos(){
  const container=document.getElementById('heroPhotos');
  /* Community/event/business photos for the hero background */
  const photos=[
    'https://images.unsplash.com/photo-1511578314322-379afb476865?w=300&q=60',
    'https://images.unsplash.com/photo-1505373877841-8d25f7d46678?w=300&q=60',
    'https://images.unsplash.com/photo-1515187029135-18ee286d815b?w=300&q=60',
    'https://images.unsplash.com/photo-1556742111-a301076d9d18?w=300&q=60',
    'https://images.unsplash.com/photo-1552664730-d307ca884978?w=300&q=60',
    'https://images.unsplash.com/photo-1497366216548-37526070297c?w=300&q=60',
    'https://images.unsplash.com/photo-1519167758481-83f29da8fd94?w=300&q=60',
    'https://images.unsplash.com/photo-1514933651103-005eec06c04b?w=300&q=60',
    'https://images.unsplash.com/photo-1542744173-8e7e53415bb0?w=300&q=60',
    'https://images.unsplash.com/photo-1521737604893-d14cc237f11d?w=300&q=60',
    'https://images.unsplash.com/photo-1543269865-cbf427effbad?w=300&q=60',
    'https://images.unsplash.com/photo-1517245386807-bb43f82c33c4?w=300&q=60'
  ];
  /* Create 3 rows of scrolling photos */
  for(let r=0;r<3;r++){
    const row=document.createElement('div');
    row.className='hero-photos-row'+(r%2===1?' reverse':'');
    /* Duplicate photos for seamless loop */
    const shuffled=[...photos].sort(()=>Math.random()-.5);
    const combined=[...shuffled,...shuffled];
    combined.forEach(url=>{
      const img=document.createElement('img');
      img.className='hero-photo';
      img.src=url;
      img.alt='community';
      img.loading='lazy';
      img.onerror=function(){this.style.display='none'};
      row.appendChild(img);
    });
    container.appendChild(row);
  }
}

/* ========== SCROLL REVEAL ========== */
function initScrollReveal(){
  const obs=new IntersectionObserver((entries)=>{
    entries.forEach((e,idx)=>{
      if(e.isIntersecting){
        setTimeout(()=>e.target.classList.add('visible'), idx*50);
        obs.unobserve(e.target);
      }
    })
  },{threshold:.08,rootMargin:'0px 0px -30px 0px'});
  document.querySelectorAll('.reveal,.reveal-left,.reveal-right,.reveal-scale').forEach(el=>obs.observe(el));
}

/* ========== NAV SCROLL ========== */
function initNavScroll(){
  const nav=document.getElementById('navbar');
  let lastY=0;
  const check=()=>{
    const y=window.scrollY;
    if(y>80){nav.classList.remove('at-top');nav.classList.add('scrolled')}
    else{nav.classList.add('at-top');nav.classList.remove('scrolled')}
    lastY=y;
  };
  window.addEventListener('scroll',check,{passive:true});
  check();
}

/* ========== SCROLL PROGRESS ========== */
function initScrollProgress(){
  const bar=document.getElementById('scrollProgress');
  window.addEventListener('scroll',()=>{
    const h=document.documentElement.scrollHeight-window.innerHeight;
    bar.style.width=(window.scrollY/h*100)+'%';
  },{passive:true});
}

/* ========== CURSOR GLOW ========== */
function initCursorGlow(){
  if(window.matchMedia('(hover:hover)').matches){
    const g=document.getElementById('cursorGlow');
    document.addEventListener('mousemove',e=>{
      g.style.left=e.clientX+'px';g.style.top=e.clientY+'px';
    },{passive:true});
  }
}

/* ========== BACK TO TOP ========== */
function initBackToTop(){
  const btn=document.getElementById('backToTop');
  window.addEventListener('scroll',()=>{
    btn.classList.toggle('visible',window.scrollY>400);
  },{passive:true});
}

/* ========== COUNTER SECTION ========== */
function initCounterSection(){
  const obs=new IntersectionObserver((entries)=>{
    entries.forEach(e=>{
      if(e.isIntersecting){
        e.target.querySelectorAll('.counter-num').forEach(el=>{
          const t=parseInt(el.dataset.count);
          animNum2(el,t);
        });
        obs.unobserve(e.target);
      }
    });
  },{threshold:.3});
  document.querySelectorAll('.counter-section').forEach(s=>obs.observe(s));
}
function animNum2(el,t){
  let c=0;const dur=1500;const start=performance.now();
  const ease=x=>x<.5?4*x*x*x:1-Math.pow(-2*x+2,3)/2;
  function tick(now){
    const p=Math.min((now-start)/dur,1);
    el.textContent=Math.floor(ease(p)*t);
    if(p<1) requestAnimationFrame(tick);
    else el.textContent=t;
  }
  requestAnimationFrame(tick);
}

/* ========== FAQ TOGGLE ========== */
function toggleFaq(el){
  const item=el.parentElement;
  const wasActive=item.classList.contains('active');
  document.querySelectorAll('.faq-item.active').forEach(i=>i.classList.remove('active'));
  if(!wasActive) item.classList.add('active');
}

/* ========== TOAST ========== */
function showToast(msg){
