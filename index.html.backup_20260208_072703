  position:relative;overflow:hidden;transition:var(--transition)}
.contact-box:hover{box-shadow:var(--sh2);transform:translateY(-2px)}
.contact-box::before{display:none}
.contact-info{display:flex;flex-direction:column;gap:.8rem;justify-content:center}
.contact-info-item{display:flex;align-items:center;gap:.7rem;padding:.65rem .8rem;border-radius:var(--r2);
  background:rgba(0,0,0,.018);transition:var(--transition);border:1px solid transparent}
.contact-info-item:hover{background:rgba(13,148,136,.04);transform:translateX(5px);border-color:rgba(13,148,136,.08)}
.contact-info-icon{width:38px;height:38px;border-radius:11px;display:flex;align-items:center;justify-content:center;
  font-size:.8rem;color:#fff;background:linear-gradient(135deg,var(--c1),var(--c3));flex-shrink:0;transition:var(--transition);
  box-shadow:0 2px 6px rgba(13,148,136,.2)}
.contact-info-item:hover .contact-info-icon{background:linear-gradient(135deg,var(--c2),var(--c1));
