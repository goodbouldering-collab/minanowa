    allMembers=members.filter(m=>m.isPublic);
    allEvents=events; allBlogs=blogs; allBoards=boards;
    allInterviews=interviews; allOpMembers=opMembers;
    if(settings.heroTitle) heroTitleText=settings.heroTitle;
    typeHeroTitle(heroTitleText);
    if(settings.heroSubtitle) document.getElementById('heroSubtitle').textContent=settings.heroSubtitle;
    if(settings.aboutText) document.getElementById('aboutSubtitle').textContent=settings.aboutText;
    animNum('cntMember',allMembers.length);
