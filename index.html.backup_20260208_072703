  font-size:.6rem;color:var(--tl);background:rgba(0,0,0,.04);border:none;
  transition:var(--transition)}
.op-social a:hover{background:var(--c1);color:#fff;transform:translateY(-2px);box-shadow:0 3px 10px rgba(13,148,136,.25)}

/* ========== LINE CTA BANNER ========== */
.line-cta{background:linear-gradient(135deg,#06c755 0%,#00b900 100%);
  border-radius:var(--r);padding:1.1rem 1.8rem;display:flex;align-items:center;justify-content:center;
  gap:1.2rem;margin-top:.5rem;color:#fff;position:relative;overflow:hidden;transition:var(--spring);cursor:pointer;
  max-width:100%}
.line-cta::before{content:'';position:absolute;inset:0;background:linear-gradient(135deg,rgba(255,255,255,.08),transparent 60%);pointer-events:none}
.line-cta:hover{transform:translateY(-4px);box-shadow:0 8px 24px rgba(6,199,85,.22),0 16px 48px rgba(6,199,85,.14)}
.line-cta-icon{font-size:1.8rem;flex-shrink:0}
.line-cta-text h3{font-size:1.15rem;font-weight:800;margin-bottom:.15rem;letter-spacing:.02em}
.line-cta-text p{font-size:.85rem;opacity:.9;font-weight:400}
.line-cta-btn{background:#fff;color:#06c755;font-weight:700;padding:.55rem 1.5rem;border-radius:24px;
  font-size:.85rem;flex-shrink:0;transition:all .4s cubic-bezier(.25,.46,.45,.94);box-shadow:0 2px 8px rgba(0,0,0,.1)}
.line-cta:hover .line-cta-btn{transform:scale(1.06);box-shadow:0 4px 16px rgba(0,0,0,.12)}

/* ========== SECTION TITLE ANIMATIONS ========== */
@keyframes title-bounce{
  0%{transform:translateY(0)}
  40%{transform:translateY(-3px)}
  100%{transform:translateY(0)}
}
@keyframes sparkle{
  0%{opacity:1;transform:translate(0,0) scale(1)}
  100%{opacity:0;transform:translate(var(--sx,10px),var(--sy,-15px)) scale(0)}
}

/* ========== GLOBAL MOBILE OVERFLOW FIX ========== */
html,body{max-width:100vw;overflow-x:hidden}
.hero,.counter-section,.sec,.sec-divider,footer,.line-cta,
.carousel-wrap,.board-list,.faq-list,.contact-grid{max-width:100%}
