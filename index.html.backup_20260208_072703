.faq-item.active .faq-a{max-height:300px;padding:0 1rem .8rem}

/* ========== CONTACT ========== */
.contact-grid{display:grid;grid-template-columns:1fr 1fr;gap:1rem;max-width:800px;margin:0 auto}
