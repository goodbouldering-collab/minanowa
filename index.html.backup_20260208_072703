    animNum('cntBlog',allBlogs.length);
    renderInterviews();renderEvents();renderMembers();renderBlogs();renderBoards();renderOpMembers();
    document.getElementById('memSearch').addEventListener('input',e=>{
      const q=e.target.value.toLowerCase();
      renderMembers(allMembers.filter(m=>m.name.toLowerCase().includes(q)||m.business.toLowerCase().includes(q)||
        m.businessCategory.toLowerCase().includes(q)||m.location.toLowerCase().includes(q)));
    });
  }catch(e){console.error(e)}
}

function animNum(id,t){
  const el=document.getElementById(id);const dur=1400;const start=performance.now();
  const ease=x=>x<.5?4*x*x*x:1-Math.pow(-2*x+2,3)/2;
  function tick(now){
    const p=Math.min((now-start)/dur,1);
    el.textContent=Math.floor(ease(p)*t);
    if(p<1) requestAnimationFrame(tick);
    else el.textContent=t;
  }
  requestAnimationFrame(tick);
}

