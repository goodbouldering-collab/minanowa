.blog-card:hover .read-more{opacity:1;transform:translateX(0)}

/* ========== BOARD ========== */
.board-list{display:flex;flex-direction:column;gap:.6rem;max-width:800px;margin:0 auto}
.board-post{background:var(--white);border:1px solid rgba(0,0,0,.05);
