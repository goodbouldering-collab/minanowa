.faq-item:hover{border-color:rgba(13,148,136,.12);box-shadow:var(--sh2);transform:translateX(3px)}
.faq-q{padding:.9rem 1.2rem;cursor:pointer;display:flex;justify-content:space-between;align-items:center;
  font-weight:600;font-size:.95rem;transition:all .4s cubic-bezier(.25,.46,.45,.94);gap:.5rem}
