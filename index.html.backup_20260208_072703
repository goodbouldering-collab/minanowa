.mem-skill:hover{background:var(--c1);color:#fff;border-color:var(--c1);transform:translateY(-1px);box-shadow:0 2px 8px rgba(13,148,136,.2)}

/* ========== BLOG CARD ========== */
.blog-card{width:270px}
