<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>みんなのWA - 彦根発 異業種交流コミュニティ</title>
<link rel="icon" type="image/svg+xml" href="/favicon.svg">
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@300;400;500;600;700;900&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
<style>
/* ========== CSS VARIABLES ========== */
:root{
  --c1:#0d9488;--c2:#0f766e;--c3:#2dd4bf;--c4:#5eead4;--c5:#99f6e4;
  --accent:#b45309;--accent2:#d97706;--accent3:#f59e0b;
  --cbg:#fafaf9;--cbg2:#f5f5f4;--cbg3:#ffffff;
  --td:#1c1917;--tl:#78716c;--tm:#57534e;--white:#fff;
  --glass:rgba(255,255,255,.85);--glass2:rgba(255,255,255,.7);--glass3:rgba(255,255,255,.95);
  --sh:0 1px 2px rgba(0,0,0,.03),0 2px 12px rgba(0,0,0,.04);
  --sh2:0 2px 4px rgba(0,0,0,.04),0 8px 28px rgba(0,0,0,.06);
  --sh3:0 4px 8px rgba(0,0,0,.04),0 16px 48px rgba(0,0,0,.06);
  --sh-glow:0 0 30px rgba(13,148,136,.1);
  --sh-glow2:0 0 50px rgba(13,148,136,.06);
  --r:16px;--r2:12px;--r3:28px;
  --transition:.3s cubic-bezier(.4,0,.2,1);
  --spring:.45s cubic-bezier(.25,.46,.45,.94);
  --ease-out:.4s cubic-bezier(0,.55,.45,1);
}

/* ========== RESET ========== */
*{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth;overflow-x:hidden;width:100%}
body{font-family:'Noto Sans JP',sans-serif;color:var(--td);background:var(--cbg);font-size:15px;
  line-height:1.75;letter-spacing:.015em;overflow-x:hidden;width:100%;position:relative;
  -webkit-font-smoothing:antialiased;-moz-osx-font-smoothing:grayscale}
body::before{content:'';position:fixed;inset:0;pointer-events:none;z-index:-2;
  background:radial-gradient(ellipse at 10% 15%,rgba(13,148,136,.04),transparent 45%),
    radial-gradient(ellipse at 90% 85%,rgba(180,83,9,.025),transparent 45%),
    radial-gradient(ellipse at 50% 50%,rgba(13,148,136,.015),transparent 60%);opacity:1}
a{color:inherit;text-decoration:none}
img{display:block;max-width:100%}
button,input,select,textarea{font-family:inherit;font-size:inherit}
::selection{background:#ccfbf1;color:#0f766e}

/* ========== LOADING SCREEN ========== */
#loadingScreen{position:fixed;inset:0;z-index:9999;background:linear-gradient(145deg,#115e59,#0d9488,#134e4a);
  display:flex;align-items:center;justify-content:center;flex-direction:column;gap:1.2rem;
  transition:opacity .7s ease,visibility .7s ease}
#loadingScreen.hide{opacity:0;visibility:hidden;pointer-events:none}
.loader-ring{width:50px;height:50px;border:3px solid rgba(255,255,255,.15);border-top-color:#fff;
  border-radius:50%;animation:spin .8s linear infinite}
@keyframes spin{to{transform:rotate(360deg)}}
.loader-text{color:rgba(255,255,255,.9);font-size:.85rem;font-weight:600;letter-spacing:.15em}
.loader-bar{width:180px;height:3px;background:rgba(255,255,255,.15);border-radius:2px;overflow:hidden}
.loader-bar-fill{height:100%;background:#fff;border-radius:2px;animation:loader-fill 1.5s ease forwards}
@keyframes loader-fill{0%{width:0}100%{width:100%}}

/* ========== CURSOR GLOW (desktop) ========== */
.cursor-glow{position:fixed;width:350px;height:350px;border-radius:50%;pointer-events:none;z-index:-1;
  background:radial-gradient(circle,rgba(13,148,136,.05),rgba(45,212,191,.02) 35%,transparent 65%);
  transform:translate(-50%,-50%);transition:transform .15s cubic-bezier(.16,1,.3,1);will-change:transform;mix-blend-mode:normal}

/* ========== SCROLL PROGRESS ========== */
.scroll-progress{position:fixed;top:0;left:0;height:3px;z-index:1001;
  background:linear-gradient(90deg,var(--c1),var(--c3),var(--accent3),var(--c3),var(--c1));background-size:300% 100%;
  animation:progress-shimmer 4s ease infinite;transition:width .1s linear}
@keyframes progress-shimmer{0%{background-position:0% 0}100%{background-position:300% 0}}

/* ========== SCROLL REVEAL ========== */
.reveal{opacity:0;transform:translateY(28px);transition:opacity .8s cubic-bezier(.16,1,.3,1),transform .8s cubic-bezier(.16,1,.3,1)}
.reveal.visible{opacity:1;transform:translateY(0)}
.reveal-left{opacity:0;transform:translateX(-35px);transition:opacity .8s cubic-bezier(.16,1,.3,1),transform .8s cubic-bezier(.16,1,.3,1)}
.reveal-left.visible{opacity:1;transform:translateX(0)}
.reveal-right{opacity:0;transform:translateX(35px);transition:opacity .8s cubic-bezier(.16,1,.3,1),transform .8s cubic-bezier(.16,1,.3,1)}
.reveal-right.visible{opacity:1;transform:translateX(0)}
.reveal-scale{opacity:0;transform:scale(.85);transition:opacity .8s cubic-bezier(.16,1,.3,1),transform .8s cubic-bezier(.16,1,.3,1)}
.reveal-scale.visible{opacity:1;transform:scale(1)}

/* ========== SECTION ========== */
.sec{padding:3.5rem 2rem 3rem;max-width:1100px;margin:0 auto;position:relative;overflow:hidden}
.sec-divider{height:1px;max-width:500px;margin:0 auto;position:relative;overflow:hidden}
.sec-divider::before{content:'';position:absolute;inset:0;
  background:linear-gradient(90deg,transparent,rgba(13,148,136,.1) 30%,rgba(45,212,191,.12) 50%,rgba(13,148,136,.1) 70%,transparent)}
.sec-head{text-align:center;margin-bottom:2rem;position:relative}
.sec-head h2{font-size:2.6rem;font-weight:800;display:flex;align-items:center;justify-content:center;gap:.55rem;
  color:var(--td);position:relative;
  cursor:default;transition:all .5s cubic-bezier(.25,.46,.45,.94);letter-spacing:-.01em;line-height:1.2}
.sec-head h2:hover{transform:translateY(-2px)}
.sec-head h2::after{content:'';position:absolute;bottom:-14px;left:50%;transform:translateX(-50%);
  width:40px;height:3px;background:linear-gradient(90deg,var(--c1),var(--c3));
  border-radius:3px;transition:width .5s cubic-bezier(.25,.46,.45,.94)}
.sec-head:hover h2::after{width:64px}
.sec-head h2 i{color:var(--c1);font-size:.45em;
  transition:all .5s cubic-bezier(.25,.46,.45,.94);
  background:none;width:auto;height:auto;
  display:inline-flex;align-items:center;justify-content:center;border-radius:0;
  box-shadow:none;opacity:.6}
.sec-head:hover h2 i{transform:scale(1.1);opacity:.8;box-shadow:none}
.sec-head p{color:var(--tl);font-size:.95rem;margin-top:1.2rem;font-weight:400;letter-spacing:.02em;
  transition:all .5s ease;line-height:1.6}
.sec-head:hover p{color:var(--tm)}

/* ========== CAROUSEL (Enhanced) ========== */
.carousel-wrap{position:relative;overflow:hidden;margin:0}
.carousel-track{display:flex;gap:.8rem;overflow-x:auto;scroll-behavior:smooth;padding:.6rem .5rem 1rem;
  scrollbar-width:none;-webkit-overflow-scrolling:touch;scroll-snap-type:x proximity}
.carousel-track::-webkit-scrollbar{display:none}
.carousel-track>*{scroll-snap-align:start}
.carousel-btn{position:absolute;top:50%;transform:translateY(-60%);z-index:5;width:36px;height:36px;
  border-radius:50%;border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;
  font-size:.75rem;transition:var(--spring);
  background:var(--glass3);backdrop-filter:blur(12px);box-shadow:0 4px 20px rgba(0,0,0,.08);color:var(--c2)}
.carousel-btn:hover{background:var(--c1);color:#fff;transform:translateY(-60%) scale(1.15);box-shadow:var(--sh-glow)}
.carousel-btn:active{transform:translateY(-60%) scale(.95)}
.carousel-btn.prev{left:6px}
.carousel-btn.next{right:6px}
/* scroll indicator dots */
.carousel-dots{display:flex;gap:4px;justify-content:center;margin-top:.2rem}
.carousel-dot{width:6px;height:6px;border-radius:50%;background:var(--c5);transition:var(--transition);cursor:pointer}
.carousel-dot.active{background:var(--c1);width:18px;border-radius:3px}

/* ========== CARD BASE ========== */
.card{background:var(--white);border:1px solid rgba(0,0,0,.05);
  border-radius:var(--r);box-shadow:var(--sh);overflow:hidden;transition:all .5s cubic-bezier(.16,1,.3,1);flex-shrink:0;
  position:relative}
.card::before{content:'';position:absolute;bottom:0;left:0;right:0;height:3px;
  background:linear-gradient(90deg,var(--c1),var(--c3),var(--accent3));transform:scaleX(0);
  pointer-events:none;z-index:3;transition:transform .6s cubic-bezier(.16,1,.3,1);transform-origin:left}
.card::after{content:'';position:absolute;inset:0;opacity:0;z-index:1;pointer-events:none;
  background:linear-gradient(135deg,rgba(13,148,136,.02),rgba(45,212,191,.03));transition:opacity .5s ease}
.card:hover{transform:translateY(-6px);box-shadow:0 12px 40px rgba(0,0,0,.08),0 4px 12px rgba(13,148,136,.06);
  border-color:rgba(13,148,136,.1)}
.card:hover::before{transform:scaleX(1)}
.card:hover::after{opacity:1}
.card-img-wrap{position:relative;overflow:hidden}
.card-img{width:100%;height:170px;object-fit:cover;transition:transform .8s cubic-bezier(.16,1,.3,1),filter .8s ease}
.card:hover .card-img{transform:scale(1.06);filter:brightness(1.03) contrast(1.02)}
.card-img-overlay{position:absolute;inset:0;background:linear-gradient(0deg,rgba(0,0,0,.35) 0%,rgba(13,148,136,.05) 100%);pointer-events:none}
.card-body{padding:.9rem 1rem;position:relative;z-index:2}
.card-tag{display:inline-block;font-size:.7rem;font-weight:600;padding:.22rem .65rem;border-radius:6px;
  margin-bottom:.3rem;letter-spacing:.04em;
  background:linear-gradient(135deg,var(--c1),var(--c3));color:#fff;
  box-shadow:0 1px 4px rgba(13,148,136,.2)}
.card-title{font-size:1.02rem;font-weight:700;line-height:1.45;margin-bottom:.3rem;
  display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;color:var(--td)}
.card-meta{color:var(--tl);font-size:.78rem;display:flex;gap:.5rem;align-items:center}

/* ========== BUTTON ========== */
.btn{display:inline-flex;align-items:center;gap:.35rem;padding:.55rem 1.3rem;border-radius:10px;border:none;
  font-weight:600;font-size:.85rem;cursor:pointer;transition:all .4s cubic-bezier(.25,.46,.45,.94);position:relative;overflow:hidden;letter-spacing:.02em}
.btn::before{content:'';position:absolute;inset:0;background:linear-gradient(180deg,rgba(255,255,255,.15),transparent);
  opacity:0;transition:var(--transition)}
.btn:hover::before{opacity:1}
.btn:active{transform:scale(.97)}
.btn-primary{background:linear-gradient(135deg,var(--c1),var(--c2));color:#fff;
  box-shadow:0 2px 6px rgba(13,148,136,.2),0 6px 20px rgba(13,148,136,.15)}
.btn-primary:hover{background:linear-gradient(135deg,var(--c2),#0a6b62);transform:translateY(-3px);box-shadow:0 6px 16px rgba(13,148,136,.22),0 12px 36px rgba(13,148,136,.18)}
.btn-outline{background:transparent;border:1.5px solid rgba(13,148,136,.25);color:var(--c1)}
.btn-outline:hover{background:var(--c1);color:#fff;border-color:var(--c1);box-shadow:0 4px 16px rgba(13,148,136,.2);transform:translateY(-2px)}
.btn-ghost{background:rgba(13,148,136,.06);color:var(--c1);border:none}
.btn-ghost:hover{background:rgba(13,148,136,.12)}
.btn-sm{padding:.35rem .8rem;font-size:.78rem}
.btn-full{width:100%;justify-content:center}
.btn-ripple{position:absolute;border-radius:50%;background:rgba(255,255,255,.4);
  transform:scale(0);animation:ripple .6s linear}
@keyframes ripple{to{transform:scale(4);opacity:0}}

/* ========== FORM ========== */
.fg{margin-bottom:.7rem}
.fg label{display:block;font-weight:600;font-size:.85rem;margin-bottom:.25rem;color:var(--td)}
.fg input,.fg select,.fg textarea{width:100%;padding:.65rem .85rem;
  border:1px solid rgba(0,0,0,.08);border-radius:10px;
  font-size:.88rem;transition:all .4s cubic-bezier(.25,.46,.45,.94);background:#fff}
.fg input:focus,.fg select:focus,.fg textarea:focus{outline:none;border-color:var(--c1);
  box-shadow:0 0 0 4px rgba(13,148,136,.08),0 2px 12px rgba(13,148,136,.06);
  transform:translateY(-1px)}
.fg textarea{resize:vertical;min-height:70px}

/* ========== NAV ========== */
nav{position:fixed;top:0;left:0;right:0;width:100%;z-index:1000;transition:var(--transition)}
nav.at-top{background:transparent}
nav.scrolled{background:rgba(255,255,255,.92);backdrop-filter:blur(28px);-webkit-backdrop-filter:blur(28px);
  box-shadow:0 1px 0 rgba(0,0,0,.03),0 4px 20px rgba(0,0,0,.03);border-bottom:none}
.nav-inner{max-width:1300px;margin:0 auto;padding:.5rem 1.2rem;display:flex;justify-content:space-between;align-items:center}
.nav-logo{font-size:1.2rem;font-weight:900;background:linear-gradient(135deg,var(--c1),var(--c3));
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;transition:var(--transition);letter-spacing:.02em}
.nav-logo:hover{transform:scale(1.03)}
nav.at-top .nav-logo{filter:brightness(3)}
.nav-links{display:flex;gap:.9rem;align-items:center;list-style:none}
.nav-links a{font-weight:500;font-size:.85rem;transition:all .4s cubic-bezier(.25,.46,.45,.94);position:relative;padding:.25rem 0;letter-spacing:.02em}
nav.at-top .nav-links a{color:rgba(255,255,255,.9)}
nav.scrolled .nav-links a{color:var(--td)}
.nav-links a::after{content:'';position:absolute;bottom:-2px;left:50%;width:0;height:2px;
  background:linear-gradient(90deg,var(--c1),var(--c3));transition:all .4s cubic-bezier(.16,1,.3,1);border-radius:1px;
  transform:translateX(-50%)}
.nav-links a:hover::after{width:100%}
.nav-links a:hover{color:var(--c1);letter-spacing:.04em}
.hamburger{display:none;background:none;border:none;font-size:1.2rem;cursor:pointer;
  color:var(--td);transition:var(--transition)}
nav.at-top .hamburger{color:#fff}
@media(max-width:768px){
  /* === NAV === */
  .nav-links{display:none;position:absolute;top:100%;left:0;right:0;
    background:rgba(255,255,255,.97);backdrop-filter:blur(24px);-webkit-backdrop-filter:blur(24px);
    flex-direction:column;padding:1.2rem 1.5rem;gap:.15rem;
    box-shadow:0 12px 40px rgba(0,0,0,.1);border-radius:0 0 20px 20px;
    border-top:1px solid rgba(13,148,136,.08)}
  .nav-links.open{display:flex}
  .nav-links li{border-bottom:1px solid rgba(0,0,0,.04)}
  .nav-links li:last-child{border-bottom:none;margin-top:.3rem}
  .nav-links a{color:var(--td) !important;padding:.7rem .2rem;font-size:.9rem;
    display:flex;align-items:center;gap:.4rem;transition:all .35s cubic-bezier(.16,1,.3,1)}
  .nav-links a:hover{color:var(--c1) !important;background:rgba(13,148,136,.04);border-radius:10px;padding-left:.6rem}
  .hamburger{display:flex;width:42px;height:42px;align-items:center;justify-content:center;
    border-radius:12px;background:rgba(255,255,255,.12);backdrop-filter:blur(8px);
    border:1px solid rgba(255,255,255,.15);transition:all .4s cubic-bezier(.16,1,.3,1)}
  .hamburger:hover{background:rgba(255,255,255,.2)}
  .hamburger i{font-size:1.1rem}
  .nav-inner{padding:0 1rem}
  .nav-logo{font-size:1.15rem !important}
  
  /* === HERO === */
  .hero{min-height:100svh}
  .hero-content{padding:1.5rem 1.2rem;margin-top:0}
  .hero h1{font-size:2.1rem !important;line-height:1.2 !important;letter-spacing:-.01em}
  .hero p{font-size:.95rem;margin-bottom:1.5rem;line-height:1.6;padding:0 .5rem}
  .hero-stats{gap:.5rem !important;padding:0 .3rem}
  .stat{min-width:0 !important;flex:1;padding:.65rem .5rem !important;border-radius:14px !important}
  .stat b{font-size:1.4rem !important}
  .stat span{font-size:.65rem;letter-spacing:.01em}
  .hero-cta{margin-top:1.5rem;gap:.6rem}
  .hero-cta .btn{padding:.72rem 1.7rem;font-size:.88rem;border-radius:14px;width:auto}
  .hero-photos-container{gap:3px !important}
  .hero-photos-row{gap:3px !important;animation-duration:25s !important}
  .hero-photo{width:75px !important;height:75px !important;border-radius:10px !important}
  .hero-scroll{bottom:1rem;font-size:.6rem}
  .hero-scroll-line{height:22px}
  .hero-glow.g1{width:350px;height:350px}
  .hero-glow.g2{width:300px;height:300px}
  .hero-glow.g3{width:250px;height:250px}
  
  /* === SECTIONS === */
  .sec{padding:2.5rem 1.2rem 2rem;overflow:hidden}
  .sec-head{margin-bottom:1.5rem}
  .sec-head h2{font-size:2rem}
  .sec-head p{font-size:.88rem;padding:0 .5rem}
  .sec-divider{margin:0 1.2rem}
  
  /* === TRUST STRIP === */
  .trust-strip{padding:.75rem 1rem}
  .trust-inner{gap:1rem}
  .trust-item{font-size:.72rem}
  .trust-item i{width:1.1rem;height:1.1rem;font-size:.55rem}
  
  /* === COUNTER === */
  .counter-section{padding:1.2rem 1rem}
  .counter-grid{grid-template-columns:repeat(2,1fr);gap:.4rem}
  .counter-num{font-size:1.7rem}
  .counter-label{font-size:.7rem}
  .counter-icon{width:30px;height:30px;font-size:.8rem;border-radius:9px}
  .counter-item:not(:last-child)::after{display:none}
  
  /* === ABOUT === */
  .about-grid{grid-template-columns:1fr !important;gap:.8rem}
  .about-card{padding:1.4rem 1.2rem;border-radius:16px}
  .about-icon{width:48px;height:48px;border-radius:13px;font-size:1.15rem}
  .about-card h3{font-size:.98rem}
  .about-card p{font-size:.84rem}
  
  /* === DX STEPS === */
  .dx-intro-text{font-size:.94rem;padding:.9rem 1rem;border-radius:14px}
  .dx-conclusion-box{padding:.9rem 1rem;border-radius:14px}
  .dx-conclusion-text{font-size:.88rem}
  
  /* === CAROUSELS === */
  .carousel-wrap{margin:0 -.2rem}
  .carousel-btn{display:none}
  .carousel-track{padding:0 .2rem;gap:.7rem;scroll-padding-left:.2rem}
  
  /* === EVENT CARDS === */
  .ev-card{width:270px;min-height:auto}
  .ev-card .card-img-wrap{height:145px}
  
  /* === MEMBER CARDS === */
  .mem-card{width:180px;padding:1rem .7rem;border-radius:14px}
  .mem-avatar-wrap{width:68px;height:68px}
  .mem-avatar{width:68px;height:68px}
  .mem-name{font-size:.86rem}
  .mem-biz{font-size:.74rem}
  .mem-skill{font-size:.6rem;padding:.1rem .35rem}
  
  /* === BLOG CARDS === */
  .blog-card{width:250px}
  .blog-card .card-img-wrap{height:140px}
  
  /* === INTERVIEW CARDS === */
  .interview-card{width:300px}
  
  /* === OP CARDS === */
  .op-card{width:175px;padding:1.2rem .8rem;border-radius:14px}
  .op-avatar-wrap{width:64px;height:64px}
  .op-avatar{width:64px;height:64px}
  .op-name{font-size:.86rem}
  
  /* === BOARD === */
  .board-list{gap:.5rem}
  .board-post{padding:.8rem .9rem;border-radius:14px}
  .board-header img{width:32px;height:32px}
  .bh-name{font-size:.84rem}
  .board-title{font-size:.88rem}
  .board-text{font-size:.82rem}
  .board-actions{gap:.4rem;flex-wrap:wrap}
  .board-action{font-size:.72rem}
  
  /* === FAQ === */
  .faq-list{gap:.5rem}
  .faq-q{padding:.75rem 1rem;font-size:.9rem}
  .faq-q i{width:22px;height:22px;font-size:.6rem}
  .faq-a{font-size:.84rem;padding:0 .9rem}
  .faq-item.active .faq-a{padding:0 .9rem .7rem}
  
  /* === CONTACT === */
  .contact-grid{grid-template-columns:1fr;gap:.8rem}
  .contact-box{padding:1.3rem;border-radius:16px}
  .contact-info-item{padding:.55rem .7rem}
  .contact-info-icon{width:34px;height:34px;border-radius:10px;font-size:.75rem}
  .contact-info-text h4{font-size:.82rem}
  .contact-info-text p{font-size:.76rem}
  
  /* === LINE CTA === */
  .line-cta{flex-direction:column;text-align:center;padding:1rem 1.2rem !important;
    gap:.8rem;border-radius:16px}
  .line-cta-icon{font-size:1.6rem}
  .line-cta-text h3{font-size:.98rem}
  .line-cta-text p{font-size:.76rem}
  .line-cta-btn{padding:.5rem 1.5rem;font-size:.82rem}
  
  /* === FOOTER === */
  .footer-grid{grid-template-columns:1fr 1fr;gap:1.5rem}
  footer{padding:2.5rem 1.2rem 1.2rem}
  .footer-grid h4{font-size:.88rem}
  .footer-grid a{font-size:.8rem}
  .footer-social a{width:34px;height:34px;font-size:.9rem}
  .footer-bot{font-size:.72rem;padding-top:1rem}
  
  /* === MODALS === */
  .modal-box{width:94%;padding:1.5rem 1.3rem;border-radius:20px;max-height:88vh}
  .modal-title{font-size:1.08rem}
  .mypage-avatar{width:64px;height:64px}
  
  /* === YT MODAL === */
  .yt-modal-inner{width:94%;border-radius:14px}
  .yt-modal-close{top:-30px;font-size:1.3rem}
  
  /* === TOAST === */
  .toast{right:1rem;left:1rem;transform:translateY(-120%);max-width:none;
    border-radius:14px;font-size:.82rem;visibility:hidden}
  .toast.show{transform:translateY(0);visibility:visible}
  
  /* === SEARCH === */
  .search-box{margin:0 0 .7rem}
  .search-box input{padding:.58rem 2.2rem .58rem .9rem;font-size:.86rem;border-radius:14px}
  
  /* === FORM INPUTS === */
  .form-group input,.form-group select,.form-group textarea{border-radius:12px;font-size:.86rem;padding:.6rem .8rem}
  .form-group label{font-size:.8rem}
  
  /* === BG SHAPES === */
  .bg-shape{opacity:.3}
  .bg-shape.s1{width:200px;height:200px}
  .bg-shape.s2{width:150px;height:150px}
  .bg-shape.s3{width:180px;height:180px}
  
  /* === BACK TO TOP === */
  .back-to-top{width:40px;height:40px;font-size:.85rem;right:1rem;bottom:1rem;border-radius:12px}
}

/* ========== HERO ========== */
.hero{margin-top:0;padding-top:0;position:relative;min-height:100vh;display:flex;align-items:center;justify-content:center;
  text-align:center;color:#fff;overflow:hidden}

/* ========== HERO PHOTO GALLERY ========== */
.hero-photos-container{position:absolute;inset:0;z-index:1;overflow:hidden;opacity:.12;
  display:flex;flex-direction:column;justify-content:center;gap:4px;pointer-events:none}
.hero-photos-row{display:flex;gap:4px;animation:hero-scroll-photos 35s linear infinite;will-change:transform}
.hero-photos-row.reverse{animation-direction:reverse}
.hero-photo{width:120px;height:120px;border-radius:12px;object-fit:cover;flex-shrink:0;
  filter:grayscale(.3);transition:filter .5s}
@keyframes hero-scroll-photos{
  0%{transform:translateX(0)}
  100%{transform:translateX(-50%)}}
.hero-bg{position:absolute;inset:0;z-index:-2;
  background:linear-gradient(155deg,#134e4a 0%,#115e59 25%,#0f766e 45%,#0d9488 65%,#115e59 85%,#1a3c40 100%);
  background-size:300% 300%;animation:hero-bg-shift 20s ease infinite}
@keyframes hero-bg-shift{0%,100%{background-position:0% 50%}50%{background-position:100% 50%}}
.hero-mesh{position:absolute;inset:0;z-index:-1;opacity:.2;
  background:radial-gradient(ellipse at 20% 40%,rgba(45,212,191,.3) 0%,transparent 50%),
    radial-gradient(ellipse at 80% 70%,rgba(217,119,6,.12) 0%,transparent 45%),
    radial-gradient(ellipse at 50% 20%,rgba(94,234,212,.15) 0%,transparent 50%)}
.hero-grid-overlay{position:absolute;inset:0;z-index:0;opacity:.04;
  background-image:linear-gradient(rgba(255,255,255,.3) 1px,transparent 1px),
    linear-gradient(90deg,rgba(255,255,255,.3) 1px,transparent 1px);
  background-size:60px 60px;animation:grid-move 20s linear infinite}
@keyframes grid-move{to{background-position:60px 60px}}
.hero-particles{position:absolute;inset:0;overflow:hidden;pointer-events:none}
.hero-glow{position:absolute;border-radius:50%;filter:blur(100px);opacity:.12;
  animation:glow-move 18s ease-in-out infinite alternate}
.hero-glow.g1{width:600px;height:600px;background:var(--c3);top:-150px;left:-150px}
.hero-glow.g2{width:500px;height:500px;background:var(--c4);bottom:-100px;right:-100px;animation-delay:-8s}
.hero-glow.g3{width:400px;height:400px;background:var(--accent2);top:40%;left:50%;animation-delay:-4s;opacity:.08}
@keyframes glow-move{0%{transform:translate(0,0) scale(1)}50%{transform:translate(40px,30px) scale(1.1)}100%{transform:translate(80px,60px) scale(1)}}
.particle{position:absolute;background:rgba(255,255,255,.05);border-radius:50%;
  animation:fl var(--dur,20s) infinite ease-in-out}
.particle.bright{background:rgba(255,255,255,.15);box-shadow:0 0 8px rgba(255,255,255,.15)}
.particle.line{width:1px !important;border-radius:0;background:rgba(255,255,255,.04);transform-origin:top}
@keyframes fl{0%,100%{transform:translateY(0) translateX(0) scale(1);opacity:.5}
  33%{transform:translateY(calc(var(--dy,-60px))) translateX(calc(var(--dx,30px))) scale(1.1);opacity:1}
  66%{transform:translateY(calc(var(--dy,-60px) * .5)) translateX(calc(var(--dx,30px) * -1)) scale(.9);opacity:.5}}
.hero-content{position:relative;z-index:10;padding:2rem;max-width:820px;margin-top:1rem;
  animation:hero-enter 1.4s cubic-bezier(.16,1,.3,1) forwards}
@keyframes hero-enter{from{opacity:0;transform:translateY(40px) scale(.97)}to{opacity:1;transform:translateY(0) scale(1)}}
.hero h1{font-size:3.2rem;font-weight:900;margin-bottom:.8rem;
  text-shadow:0 4px 40px rgba(0,0,0,.12);letter-spacing:-.02em;line-height:1.15}
.hero-typed{display:inline}
.hero-typed .cursor{display:inline-block;width:2px;height:1em;background:#fff;margin-left:2px;
  animation:blink .8s step-end infinite;vertical-align:text-bottom}
@keyframes blink{50%{opacity:0}}
.hero p{font-size:1.05rem;opacity:.85;margin-bottom:2.2rem;font-weight:300;line-height:1.7;letter-spacing:.03em}
.hero-stats{display:flex;gap:1rem;justify-content:center;flex-wrap:wrap}
.stat{background:rgba(255,255,255,.08);backdrop-filter:blur(16px);-webkit-backdrop-filter:blur(16px);padding:.8rem 1.3rem;
  border-radius:var(--r);border:1px solid rgba(255,255,255,.12);text-align:center;
  min-width:110px;transition:all .5s cubic-bezier(.16,1,.3,1);cursor:default;position:relative;overflow:hidden}
.stat::before{content:'';position:absolute;inset:0;
  background:linear-gradient(135deg,rgba(255,255,255,.05),transparent);transition:var(--transition)}
.stat:hover{background:rgba(255,255,255,.18);transform:translateY(-5px);
  box-shadow:0 12px 45px rgba(0,0,0,.15),0 0 20px rgba(45,212,191,.08);border-color:rgba(255,255,255,.3)}
.stat:hover::before{background:linear-gradient(135deg,rgba(255,255,255,.12),transparent)}
.stat b{display:block;font-size:2rem;font-weight:900;
  background:linear-gradient(135deg,#fff,var(--c4));-webkit-background-clip:text;-webkit-text-fill-color:transparent}
.stat span{font-size:.72rem;opacity:.75;font-weight:400;letter-spacing:.04em;text-transform:uppercase}
.hero-cta{margin-top:2rem;display:flex;gap:.7rem;justify-content:center;flex-wrap:wrap}
.hero-cta .btn{padding:.8rem 2.6rem;font-size:.92rem;border-radius:12px;backdrop-filter:blur(8px);font-weight:700;letter-spacing:.03em}
.hero-cta .btn-white{background:#fff;color:var(--c2);
  box-shadow:0 2px 8px rgba(0,0,0,.08),0 8px 32px rgba(0,0,0,.08)}
.hero-cta .btn-white:hover{transform:translateY(-3px);box-shadow:0 6px 16px rgba(0,0,0,.1),0 14px 44px rgba(0,0,0,.12),0 0 20px rgba(13,148,136,.06)}
.hero-cta .btn-glass{background:rgba(255,255,255,.08);color:#fff;border:1px solid rgba(255,255,255,.18)}
.hero-cta .btn-glass:hover{background:rgba(255,255,255,.15);transform:translateY(-3px);box-shadow:0 8px 32px rgba(0,0,0,.12)}
.hero-scroll{position:absolute;bottom:1.5rem;left:50%;transform:translateX(-50%);z-index:10;
  color:rgba(255,255,255,.5);font-size:.7rem;display:flex;flex-direction:column;align-items:center;gap:.3rem}
.hero-scroll-line{width:1px;height:30px;background:linear-gradient(180deg,rgba(255,255,255,.4),transparent);
  animation:scroll-pulse 2s ease-in-out infinite}
@keyframes scroll-pulse{0%,100%{opacity:.3;height:20px}50%{opacity:1;height:30px}}

/* ========== ABOUT ========== */
.about-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:1.2rem;margin-top:.5rem}
.about-card{background:var(--white);border:1px solid rgba(0,0,0,.05);
  border-radius:var(--r);padding:2rem 1.5rem 1.8rem;text-align:center;box-shadow:var(--sh);
  transition:var(--spring);position:relative;overflow:hidden;cursor:default}
.about-card::before{display:none}
.about-card:hover::before{display:none}
@keyframes about-spin{to{transform:rotate(360deg)}}
.about-card::after{content:'';position:absolute;top:0;left:0;right:0;height:3px;
  background:linear-gradient(90deg,var(--c1),var(--c3),var(--accent3));transform:scaleX(0);transition:transform .4s ease;transform-origin:left}
.about-card:hover::after{transform:scaleX(1)}
.about-card:hover{transform:translateY(-6px);box-shadow:0 12px 35px rgba(0,0,0,.07),0 4px 12px rgba(13,148,136,.08)}
.about-icon{width:54px;height:54px;border-radius:14px;display:flex;align-items:center;justify-content:center;
  margin:0 auto .9rem;font-size:1.25rem;color:#fff;
  background:linear-gradient(135deg,var(--c1),var(--c3));transition:var(--spring);
  box-shadow:0 4px 14px rgba(13,148,136,.25)}
.about-card:hover .about-icon{background:linear-gradient(135deg,var(--c2),var(--c1));transform:scale(1.1) rotate(5deg);
  box-shadow:0 4px 14px rgba(13,148,136,.3)}
.about-card h3{font-size:1.1rem;font-weight:700;margin-bottom:.4rem;color:var(--td)}
.about-card p{font-size:.88rem;color:var(--tl);line-height:1.7}

/* ========== DX EXPLANATION (About Extension) ========== */
.dx-intro{margin-top:2rem;text-align:center;position:relative}
.dx-intro-text{font-size:1rem;font-weight:400;line-height:1.85;color:var(--tm);max-width:720px;margin:0 auto;
  padding:1.5rem 2rem;background:linear-gradient(135deg,#f0fdfa,#fff);border:1px solid rgba(13,148,136,.06);border-radius:var(--r);
  box-shadow:var(--sh);position:relative;overflow:hidden;transition:var(--transition)}
.dx-intro-text:hover{box-shadow:var(--sh2)}
.dx-intro-text::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;
  background:linear-gradient(90deg,var(--c1),var(--c3),var(--accent3));transition:none}
.dx-intro-text:hover::before{}
@keyframes rainbow-bar{0%{background-position:0% 0}100%{background-position:300% 0}}
.dx-intro-text .dx-highlight{font-weight:700;color:var(--c1);
  background:rgba(13,148,136,.08);padding:.05rem .35rem;border-radius:4px}
.dx-intro-text .dx-highlight::after{display:none}

/* Steps */
.dx-steps{display:flex;flex-direction:column;gap:1rem;margin-top:1.5rem;position:relative;padding-left:.5rem}
.dx-steps::before{content:'';position:absolute;left:calc(.5rem + 22px);top:0;bottom:0;width:2px;
  background:linear-gradient(180deg,var(--c1),var(--c3),#0891b2,#7c3aed,#f59e0b);
  border-radius:1px;z-index:0;opacity:.4}
.dx-step{display:flex;gap:.8rem;align-items:flex-start;position:relative;z-index:1;
  opacity:0;transform:translateX(-25px);transition:opacity .5s cubic-bezier(.4,0,.2,1),
  transform .5s cubic-bezier(.4,0,.2,1)}
.dx-step.dx-visible{opacity:1;transform:translateX(0)}

/* Step numbers — each has unique color */
.dx-step-num{width:50px;height:50px;border-radius:14px;display:flex;align-items:center;justify-content:center;
  font-size:.95rem;font-weight:700;flex-shrink:0;position:relative;
  transition:var(--spring);cursor:pointer;flex-direction:column;gap:0}
.dx-step-number{font-size:.5rem;font-weight:600;opacity:.5;line-height:1;letter-spacing:.05em;
  position:absolute;top:3px;right:5px}
.dx-step-num::after{content:'';position:absolute;inset:-2px;border-radius:14px;
  border:1.5px solid currentColor;opacity:0;transition:var(--transition)}
.dx-step:hover .dx-step-num{transform:scale(1.1) rotate(3deg)}
.dx-step:hover .dx-step-num::after{opacity:.2}
@keyframes step-ring-pulse{0%,100%{transform:scale(1);opacity:.1}50%{transform:scale(1.1);opacity:.25}}
@keyframes step-click-pulse{0%{transform:scale(1)}40%{transform:scale(1.15)}100%{transform:scale(1.08)}}
.dx-step-num i{transition:var(--spring);font-size:1rem}
.dx-step:hover .dx-step-num i{transform:scale(1.1)}

/* Color themes for each step */
.dx-step-num.s-orange{background:linear-gradient(135deg,#fbbf24,#f59e0b);color:#fff;box-shadow:0 2px 8px rgba(245,158,11,.25)}
.dx-step-num.s-green{background:linear-gradient(135deg,#2dd4bf,#0d9488);color:#fff;box-shadow:0 2px 8px rgba(13,148,136,.25)}
.dx-step-num.s-cyan{background:linear-gradient(135deg,#22d3ee,#0891b2);color:#fff;box-shadow:0 2px 8px rgba(8,145,178,.25)}
.dx-step-num.s-purple{background:linear-gradient(135deg,#a78bfa,#7c3aed);color:#fff;box-shadow:0 2px 8px rgba(124,58,237,.25)}

/* Step content card */
.dx-step-content{flex:1;border-radius:var(--r2);padding:.9rem 1.1rem;
  transition:var(--transition);position:relative;overflow:hidden;cursor:pointer}
/* Each step card has tinted background */
.dx-step[data-color="orange"] .dx-step-content{background:linear-gradient(135deg,#fffbeb,#fff);border:1px solid rgba(245,158,11,.1)}
.dx-step[data-color="green"] .dx-step-content{background:linear-gradient(135deg,#f0fdfa,#fff);border:1px solid rgba(13,148,136,.1)}
.dx-step[data-color="cyan"] .dx-step-content{background:linear-gradient(135deg,#ecfeff,#fff);border:1px solid rgba(8,145,178,.1)}
.dx-step[data-color="purple"] .dx-step-content{background:linear-gradient(135deg,#f5f3ff,#fff);border:1px solid rgba(124,58,237,.1)}

.dx-step-content::before{content:'';position:absolute;top:0;left:0;bottom:0;width:3px;
  transform:scaleY(0);transition:transform .4s cubic-bezier(.175,.885,.32,1.275);transform-origin:top}
.dx-step[data-color="orange"] .dx-step-content::before{background:#d97706}
.dx-step[data-color="green"] .dx-step-content::before{background:#0d9488}
.dx-step[data-color="cyan"] .dx-step-content::before{background:#0891b2}
.dx-step[data-color="purple"] .dx-step-content::before{background:#7c3aed}

.dx-step:hover .dx-step-content{transform:translateX(4px)}
.dx-step:hover .dx-step-content::before{transform:scaleY(1)}
.dx-step[data-color="orange"]:hover .dx-step-content{box-shadow:var(--sh2);border-color:rgba(217,119,6,.12)}
.dx-step[data-color="green"]:hover .dx-step-content{box-shadow:var(--sh2);border-color:rgba(13,148,136,.12)}
.dx-step[data-color="cyan"]:hover .dx-step-content{box-shadow:var(--sh2);border-color:rgba(8,145,178,.12)}
.dx-step[data-color="purple"]:hover .dx-step-content{box-shadow:var(--sh2);border-color:rgba(124,58,237,.12)}

/* Step title — each color */
.dx-step-content h4{font-size:1.05rem;font-weight:700;margin-bottom:.4rem;display:flex;align-items:center;gap:.35rem;
  flex-wrap:wrap;transition:all .4s cubic-bezier(.25,.46,.45,.94);letter-spacing:.01em}
.dx-step[data-color="orange"] h4{color:#92400e}
.dx-step[data-color="green"] h4{color:#065f46}
.dx-step[data-color="cyan"] h4{color:#155e75}
.dx-step[data-color="purple"] h4{color:#5b21b6}
.dx-step-content p{font-size:.92rem;color:var(--tl);line-height:1.75}

/* Keywords — colored per step */
.dx-step-content .dx-keyword{display:inline-block;font-weight:600;padding:.12rem .45rem;border-radius:4px;
  font-size:.82rem;transition:all .4s cubic-bezier(.25,.46,.45,.94)}
.dx-step[data-color="orange"] .dx-keyword{background:rgba(245,158,11,.1);color:#92400e;border:1px solid rgba(245,158,11,.15)}
.dx-step[data-color="green"] .dx-keyword{background:rgba(13,148,136,.1);color:#065f46;border:1px solid rgba(13,148,136,.15)}
.dx-step[data-color="cyan"] .dx-keyword{background:rgba(8,145,178,.1);color:#155e75;border:1px solid rgba(8,145,178,.15)}
.dx-step[data-color="purple"] .dx-keyword{background:rgba(124,58,237,.1);color:#5b21b6;border:1px solid rgba(124,58,237,.15)}
.dx-step:hover .dx-keyword{transform:translateY(-2px);box-shadow:0 2px 6px rgba(0,0,0,.06)}

/* Active step (clicked) — glow up */
.dx-step.dx-active .dx-step-num{transform:scale(1.08)}
.dx-step.dx-active .dx-step-content::before{transform:scaleY(1)}
.dx-step.dx-active .dx-step-content{box-shadow:var(--sh2)}

/* Conclusion */
.dx-conclusion{margin-top:1.5rem;position:relative}
.dx-conclusion-box{background:linear-gradient(140deg,#134e4a 0%,#0f766e 40%,#0d9488 70%,#115e59 100%);
  border-radius:var(--r);padding:1.5rem 1.8rem;color:#fff;position:relative;overflow:hidden;
  box-shadow:0 6px 20px rgba(0,0,0,.08),0 16px 48px rgba(13,148,136,.12);transition:var(--transition);cursor:default}
@keyframes conclusion-shift{0%,100%{background-position:0% 50%}50%{background-position:100% 50%}}
.dx-conclusion-box::before{content:'';position:absolute;inset:0;
  background:radial-gradient(ellipse at 20% 50%,rgba(255,255,255,.1),transparent 60%),
    radial-gradient(ellipse at 80% 30%,rgba(52,211,153,.08),transparent 50%);pointer-events:none}
.dx-conclusion-box::after{content:'';position:absolute;top:-50%;left:-50%;width:200%;height:200%;
  background:conic-gradient(from 0deg,transparent,rgba(255,255,255,.02),transparent,rgba(255,255,255,.04),transparent);
  animation:about-spin 15s linear infinite;pointer-events:none}
.dx-conclusion-box:hover{transform:translateY(-2px);box-shadow:0 8px 24px rgba(0,0,0,.1),0 16px 48px rgba(13,148,136,.15)}
.dx-conclusion-label{display:inline-flex;align-items:center;gap:.3rem;font-size:.6rem;font-weight:700;
  letter-spacing:.1em;text-transform:uppercase;opacity:1;margin-bottom:.3rem;
  padding:.2rem .55rem;background:rgba(255,255,255,.18);border-radius:8px;backdrop-filter:blur(4px);
  border:1px solid rgba(255,255,255,.15)}
.dx-conclusion-text{font-size:1rem;font-weight:600;line-height:1.7;position:relative;z-index:1}
.dx-conclusion-text strong{font-weight:700;color:#fff}
@keyframes gold-shimmer{0%,100%{background-position:0% 50%}50%{background-position:100% 50%}}
.dx-conclusion-cta{margin-top:.6rem;display:flex;gap:.5rem;position:relative;z-index:1;flex-wrap:wrap}

/* Mobile DX */
@media(max-width:768px){
  .dx-steps{padding-left:.3rem;gap:.8rem}
  .dx-steps::before{left:calc(.3rem + 19px)}
  .dx-step-num{width:40px;height:40px;font-size:.82rem;border-radius:12px}
  .dx-step-content{padding:.8rem .9rem;border-radius:14px}
  .dx-step-content h4{font-size:.94rem}
  .dx-step-content p{font-size:.84rem;line-height:1.6}
  .dx-intro-text{font-size:.92rem;padding:.85rem 1rem;border-radius:14px}
  .dx-conclusion-box{padding:.85rem 1rem;border-radius:14px}
  .dx-conclusion-text{font-size:.88rem}
  .dx-keyword{font-size:.8rem;padding:.15rem .4rem}
}
@media(max-width:480px){
  .dx-steps{padding-left:.2rem;gap:.7rem}
  .dx-steps::before{left:calc(.2rem + 14px)}
  .dx-step-num{width:30px;height:30px;font-size:.68rem;border-radius:9px}
  .dx-step-num::after{inset:-2px;border-radius:11px}
  .dx-step{gap:.45rem}
  .dx-step-content{padding:.65rem .75rem;border-radius:12px}
  .dx-step-content h4{font-size:.82rem}
  .dx-step-content p{font-size:.74rem}
  .dx-intro-text{font-size:.78rem;padding:.65rem .75rem;border-radius:12px}
  .dx-keyword{font-size:.7rem;padding:.12rem .35rem}
}

/* ========== SECTION COLOR TINTS ========== */
#about{background:linear-gradient(180deg,#f0fdfa 0%,#f5f5f4 100%)}
#events{background:linear-gradient(180deg,#fefce8 0%,#fffbeb 50%,#fafaf9 100%)}
#members{background:linear-gradient(180deg,#f0f9ff 0%,#f5f5f4 100%)}
#blogs{background:linear-gradient(180deg,#fdf2f8 0%,#fafaf9 100%)}
#boards{background:linear-gradient(180deg,#f5f3ff 0%,#f5f5f4 100%)}
#faq{background:linear-gradient(180deg,#f0fdfa 0%,#ecfdf5 50%,#fafaf9 100%)}
#contact{background:linear-gradient(180deg,#fffbeb 0%,#f5f5f4 100%)}

/* ========== EVENT CARD ========== */
.ev-card{width:295px;min-height:310px;display:flex;flex-direction:column}
.ev-card .card-body{flex:1;display:flex;flex-direction:column}
.ev-date{color:var(--c1);font-weight:600;font-size:.8rem;margin-bottom:.2rem;display:flex;align-items:center;gap:.3rem}
.ev-loc{color:var(--tl);font-size:.8rem;margin-bottom:.4rem;display:flex;align-items:center;gap:.3rem}
.ev-footer{margin-top:auto;padding-top:.4rem;display:flex;justify-content:space-between;align-items:center;
  border-top:1px solid rgba(16,185,129,.06)}
.ev-fee{font-size:.78rem;color:var(--td);font-weight:600}
.ev-cap{font-size:.72rem;color:var(--tl);display:flex;align-items:center;gap:.2rem}
.ev-badge{position:absolute;top:.6rem;right:.6rem;z-index:3;padding:.22rem .6rem;
  border-radius:8px;font-size:.68rem;font-weight:700;backdrop-filter:blur(8px);
  box-shadow:0 2px 8px rgba(0,0,0,.1)}
.ev-badge.upcoming{background:linear-gradient(135deg,#10b981,#059669);color:#fff}
.ev-badge.past{background:rgba(100,116,139,.7);color:#fff}
/* pulse on upcoming */
.ev-badge.upcoming::after{content:'';position:absolute;inset:-2px;border-radius:10px;
  border:2px solid rgba(16,185,129,.4);animation:badge-pulse 2s ease-in-out infinite}
@keyframes badge-pulse{0%,100%{opacity:0;transform:scale(1)}50%{opacity:1;transform:scale(1.05)}}

/* ========== MEMBER CARD ========== */
.mem-card{width:220px;text-align:center;padding:1.2rem .9rem;cursor:default}
.mem-avatar-wrap{position:relative;width:78px;height:78px;margin:0 auto .5rem}
.mem-avatar{width:78px;height:78px;border-radius:50%;object-fit:cover;
  border:3px solid transparent;background:linear-gradient(#fff,#fff) padding-box,
    linear-gradient(135deg,var(--c1),var(--c3)) border-box;
  transition:var(--spring)}
.mem-card:hover .mem-avatar{transform:scale(1.08);box-shadow:0 6px 24px rgba(13,148,136,.25)}
