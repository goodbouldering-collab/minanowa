{
  "version": 2,
  "rewrites": [
    { "source": "/blog/:id", "destination": "/api/ssr/blog/[id]" },
    { "source": "/event/:id", "destination": "/api/ssr/event/[id]" },
    { "source": "/event/:id/ics", "destination": "/api/ssr/event/[id]/ics" },
    { "source": "/feed", "destination": "/api/ssr/feed" },
    { "source": "/rss", "destination": "/api/ssr/feed" }
  ],
  "functions": {
    "api/**/*.js": {
      "maxDuration": 60
    }
  },
  "headers": [
    {
      "source": "/(index|admin)\\.html",
      "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
    },
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Service-Worker-Allowed", "value": "/" }
      ]
    },
    {
      "source": "/(.*)\\.(png|jpg|jpeg|gif|webp|avif|ico|svg|woff2?|ttf|otf)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=2592000, stale-while-revalidate=86400" }
      ]
    }
  ]
}
